{
	"info": {
		"_postman_id": "6f1a2b3c-4d5e-4f60-9a10-weatherapp001",
		"name": "Weather App API",
		"description": "CRUD API for weather records (Spring Boot 3 + MySQL + Redis cache). Base path: /api/v1/weather. No authentication yet (JWT security is a later step).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Create Weather",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test(\"status is 201\", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"var body = pm.response.json();",
							"if (body && body.id) {",
							"    pm.collectionVariables.set(\"weatherId\", body.id);",
							"    pm.collectionVariables.set(\"city\", body.city);",
							"}"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"city\": \"London\",\n    \"details\": \"Cloudy\",\n    \"temperature\": 14.5,\n    \"humidity\": 80\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/weather/create",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"weather",
						"create"
					]
				},
				"description": "Create a new weather record. Returns 201 with the created record; 400 on validation failure; 409 if the city already exists."
			},
			"response": []
		},
		{
			"name": "Get All Weather (paged)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/weather?page=0&size=10&sort=id,asc",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"weather"
					],
					"query": [
						{
							"key": "page",
							"value": "0"
						},
						{
							"key": "size",
							"value": "10"
						},
						{
							"key": "sort",
							"value": "id,asc"
						}
					]
				},
				"description": "List weather records with Spring pagination. Supports page, size and sort (e.g. sort=city,desc)."
			},
			"response": []
		},
		{
			"name": "Get Weather by Id",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/weather/{{weatherId}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"weather",
						"{{weatherId}}"
					]
				},
				"description": "Fetch a single record by id (Redis-cached). Returns 404 if not found."
			},
			"response": []
		},
		{
			"name": "Get Weather by City",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/weather/city/{{city}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"weather",
						"city",
						"{{city}}"
					]
				},
				"description": "Fetch a single record by city (Redis-cached). Returns 404 if not found."
			},
			"response": []
		},
		{
			"name": "Update Weather",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"city\": \"London\",\n    \"details\": \"Rainy\",\n    \"temperature\": 9.0,\n    \"humidity\": 95\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/v1/weather/{{weatherId}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"weather",
						"{{weatherId}}"
					]
				},
				"description": "Full update of an existing record by id. Returns 200; 404 if not found; 409 if the new city belongs to another record; 400 on validation failure."
			},
			"response": []
		},
		{
			"name": "Delete Weather",
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/v1/weather/{{weatherId}}",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"v1",
						"weather",
						"{{weatherId}}"
					]
				},
				"description": "Delete a record by id. Returns 200; 404 if not found."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080"
		},
		{
			"key": "weatherId",
			"value": "1"
		},
		{
			"key": "city",
			"value": "London"
		}
	]
}
